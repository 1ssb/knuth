{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/bundle.schema.json",
  "title": "LLM Audit Bundle Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_version",
    "bundle_id",
    "description",
    "rulesets",
    "schemas",
    "defaults"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "bundle_version": {
      "type": "string"
    },
    "bundle_id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "rulesets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "ruleset_id",
          "path"
        ],
        "properties": {
          "ruleset_id": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "embedded": {
            "type": "object"
          }
        }
      }
    },
    "schemas": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recommended_rulesets_by_task",
        "severity_policy"
      ],
      "properties": {
        "recommended_rulesets_by_task": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "severity_policy": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
