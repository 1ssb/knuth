{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/rule_set.schema.json",
  "title": "LLM Audit Rule Set Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ruleset_id",
    "title",
    "description",
    "rules"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "ruleset_id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "scope": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "strictness_levels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "default_strictness": {
      "type": "string"
    },
    "provenance": {
      "type": "object"
    },
    "venue_profiles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "severity",
          "check",
          "pass_criteria",
          "fix_template"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "applies_to": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "title": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": [
              "critical",
              "major",
              "minor",
              "info"
            ]
          },
          "rationale": {
            "type": "string"
          },
          "check": {
            "type": "string"
          },
          "pass_criteria": {
            "type": "string"
          },
          "exceptions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "bad_examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "good_examples": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "failure_modes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fix_template": {
            "type": "string"
          }
        }
      }
    }
  }
}
